generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum BotRole {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}

model User {
  id        String   @id
  name      String?
  avatar    String?

  bots      Bot[]
  accesses  BotAccess[]
  logs      PanelLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Bot {
  id        String   @id
  name      String
  avatar    String?
  apiUrl    String?

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  accesses  BotAccess[]
  logs      PanelLog[]

  lastHeartbeat DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BotAccess {
  id        String   @id @default(cuid())

  botId     String
  bot       Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  role      BotRole  @default(OWNER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([botId, userId])
}

model PanelLog {
  id        String   @id @default(cuid())

  botId     String
  bot       Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  action    String
  detail    String?

  createdAt DateTime @default(now())
}